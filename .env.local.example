NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# ── Order pipeline cutover (SB6) ──────────────────────────────────────────────

# Feature flag — defaults to enabled. Set to "false" to pause the /orders and
# /kds pages during an emergency rollback. Toggles take effect on the next
# Vercel deploy (or instantly if updated as a Vercel env var with redeploy).
NEXT_PUBLIC_ORDER_PIPELINE_ENABLED=true

# Cutover window — both must be set together (YYYY-MM-DD format).
# - Days 1 to halfway: blue "Parallel running" banner on dashboard
# - Halfway to last day: amber "mfsops is primary" banner on dashboard
# - Outside window: no banner
# Unset to disable banner entirely.
NEXT_PUBLIC_ORDER_CUTOVER_START=
NEXT_PUBLIC_ORDER_CUTOVER_END=
